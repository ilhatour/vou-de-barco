# Vou de Barco — controle de cache (evita servir versão antiga após deploy)
<IfModule mod_headers.c>
  # HTML/CSS/JS/imagens: sempre revalidar (nunca servir versão velha após troca)
  <FilesMatch "\.(html|css|js|jpg|jpeg|png|gif|svg|webp|ico)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType image/jpeg "access plus 0 seconds"
  ExpiresByType image/png "access plus 0 seconds"
  ExpiresByType image/svg+xml "access plus 0 seconds"
</IfModule>
